rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cho phép đọc employees và users mà không cần auth
    // — cần thiết cho flow login phone+PIN: verify SĐT trước khi tạo account
    match /employees/{employeeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // FCM tokens — chỉ user của chính mình
    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Notifications — field dùng là 'userId' (không phải recipientId)
    match /notifications/{notifId} {
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;

      allow create: if request.auth != null;

      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      allow delete: if false;
    }

    // Tất cả collection khác — cần auth
    match /{collection}/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
