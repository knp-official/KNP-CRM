rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — chỉ đọc/ghi profile của chính mình
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // FCM tokens — chỉ user của chính mình
    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Notifications — field dùng là 'userId' (không phải recipientId)
    match /notifications/{notifId} {
      // Đọc: user xem notification của chính mình
      allow read: if request.auth != null &&
        resource.data.userId == request.auth.uid;

      // Tạo: bất kỳ user đã đăng nhập (admin/manager tạo thông báo cho người khác)
      allow create: if request.auth != null;

      // Update: chỉ được sửa field 'read' — không được sửa nội dung
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // Xóa: không cho phép từ client
      allow delete: if false;
    }

    // Employees, Customers, Tasks, Quotes, Debts — chỉ user đã đăng nhập
    match /{collection}/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
